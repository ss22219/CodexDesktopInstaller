<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexInstaller.Desktop.ViewModels"
             x:Class="CodexInstaller.Desktop.Views.InstallPage"
             x:DataType="vm:InstallPageViewModel">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="480" Spacing="20">
        <TextBlock Text="正在安装..." FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>

        <Grid Height="24" ColumnDefinitions="*,54" ColumnSpacing="12">
            <ProgressBar Grid.Column="0"
                         Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"
                         Height="8" VerticalAlignment="Center"
                         CornerRadius="4"
                         IsIndeterminate="{Binding IsIndeterminate}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding ProgressText}" FontSize="12" FontWeight="SemiBold"
                       TextAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="#444"/>
        </Grid>

        <TextBlock Text="{Binding StatusText}" FontSize="14"
                   HorizontalAlignment="Center" TextAlignment="Center"
                   TextWrapping="Wrap" Foreground="Gray"/>

        <TextBlock Text="{Binding ErrorMessage}" FontSize="13"
                   HorizontalAlignment="Center" Foreground="#E04040"
                   TextWrapping="Wrap"/>

        <TextBlock Text="请勿关闭此窗口..." FontSize="11"
                   HorizontalAlignment="Center" Foreground="#999"/>
    </StackPanel>
</UserControl>
