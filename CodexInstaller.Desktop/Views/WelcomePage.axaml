<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexInstaller.Desktop.ViewModels"
             x:Class="CodexInstaller.Desktop.Views.WelcomePage"
             x:DataType="vm:WelcomePageViewModel">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Spacing="16">
        <TextBlock Text="欢迎安装 Codex 免费启动" FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="本安装程序会部署一套独立环境，不替换官方 Codex。"
                   TextWrapping="Wrap" HorizontalAlignment="Center"
                   TextAlignment="Center" Foreground="Gray"/>
        <Separator Margin="0,8"/>
        <TextBlock Text="安装目录:" FontSize="13"/>
        <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" Text="{Binding InstallDir}" CornerRadius="4" Padding="8"/>
            <Button Grid.Column="1" Content="浏览" Click="BrowseInstallDir_Click"
                    Width="72" Height="36" Margin="8,0,0,0"
                    CornerRadius="8"/>
        </Grid>
        <TextBlock Text="安装说明：默认使用内置免费模型配置，和官方 Codex 环境分开。"
                   TextWrapping="Wrap" FontSize="12" Foreground="#888"/>
        <Button Content="开始安装" Command="{Binding InstallCommand}"
                HorizontalAlignment="Center" Width="200" Height="40"
                FontSize="15" FontWeight="SemiBold"
                Background="{StaticResource SystemAccentColor}"
                Foreground="White" CornerRadius="8"/>
    </StackPanel>
</UserControl>
